            energy: 0,
            maxEnergy: 3,
            position: 0
        },
        inventory: {
            cards: [],
            items: ['Loaded Dice']
        },
        buffs: []
    },
    deck: {
        drawPile: [],
        hand: [],
        discardPile: [],
        exhaustPile: []
    },
    combat: {
        enemy: { hp: 0, maxHp: 0, block: 0, type: '' },
        playerBlock: 0,
        turn: 'player'
    },
    meta: {
        bossTokens: 0,
        currentView: 'view-class-selection'
    }
};

let gameState = null;

const CLASS_CONFIGS = {
    Warrior: { maxHp: 80, initialDeck: ["Strike", "Strike", "Defend", "Defend", "Bash"] },
    Priest:  { maxHp: 60, initialDeck: ["Smite", "Smite", "Heal", "Defend", "Pray"] },
